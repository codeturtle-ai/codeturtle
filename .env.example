# DigitalOcean Gradient AI Platform API Key
# Get yours at: https://cloud.digitalocean.com/account/api/tokens
GRADIENT_AI_API_KEY=your_digitalocean_token_here

# GitHub Personal Access Token (optional but recommended)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Optional: Custom API endpoint (if different)
# GRADIENT_AI_ENDPOINT=https://api.digitalocean.com/v2/ai
